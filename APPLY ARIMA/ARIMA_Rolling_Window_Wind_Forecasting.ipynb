   "source": [
    "## 5. Comparison & Results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create comparison table\n",
    "results = [\n",
    "    (\"Traditional ARIMA (2-year)\", mae_trad, rmse_trad, pred_trad.std()),\n",
    "    (\"Rolling: 4 weeks → 1 day\", mae_4w, rmse_4w, preds_4w.std()),\n",
