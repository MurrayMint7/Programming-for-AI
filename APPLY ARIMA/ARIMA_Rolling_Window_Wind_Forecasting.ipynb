    "\n",
    "plt.figure(figsize=(15, 6))\n",
    "plt.plot(test_dates_2w, actuals_2w, label='Actual', color='red', linewidth=2.5, marker='o', markersize=4, alpha=0.7)\n",
    "plt.plot(test_dates_2w, preds_2w, label='Rolling ARIMA Forecast', color='blue', linewidth=2, linestyle='--', alpha=0.8)\n",
    "plt.fill_between(test_dates_2w, actuals_2w, preds_2w, alpha=0.2, color='gray')\n",
