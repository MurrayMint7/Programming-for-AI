    "\n",
    "best_mae = results_sorted[0][1]\n",
    "\n",
    "for rank, (desc, mae, rmse, var) in enumerate(results_sorted, 1):\n",
    "    pct = (1 - mae / best_mae) * 100\n",
    "    marker = \"🏆 BEST\" if rank == 1 else f\"{pct:+.1f}%\"\n",
    "    print(f\"{rank:<6} {desc:<40} {mae:>10.4f}   {rmse:>10.4f}   {var:>10.4f}   {marker}\")\n",
    "\n",
    "print(\"\\n\" + \"=\"*90)"
   ]
