    "plt.text(0.02, 0.95, f'MAE: {mae_2w:.4f} knots\\nVar: {preds_2w.std():.4f}\\nImprovement: {improvement_2w:+.1f}%', \n",
    "         transform=plt.gca().transAxes, fontsize=11, verticalalignment='top',\n",
    "         bbox=dict(boxstyle='round', facecolor='lightblue', alpha=0.8))\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
